{
  "name": "magic-kids-desktop",
  "version": "1.0.0",
  "description": "Magic Kids Desktop - Reproductor vintage con stream en vivo",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --config",
    "build:mac": "electron-builder --mac --config",
    "build:portable": "electron-builder --win portable --config"
  },
  "build": {
    "appId": "com.magickids.desktop",
    "productName": "Magic Kids Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "prueba.html",
      "control-remoto.html",
      "tv-retro.jpg",
      "icon.ico",
      "icon-192.png",
      "icon-512.png",
      "manifest.json",
      "sw.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "sign": false,
      "signAndEditExecutable": false
    },
    "mac": {
      "icon": "icon-mac.png",
      "target": ["zip"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "license": false,
      "artifactName": "Magic-Kids-Desktop-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "playok24",
      "repo": "magic-kids-desktop",
      "releaseType": "release"
    },
    "portable": {
      "artifactName": "TV-Retro-Portable-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
